<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>HousingPolicy.Api</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Dapper" Version="2.1.66" />
    <PackageReference Include="Npgsql" Version="8.0.5" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="7.2.0" />
  </ItemGroup>

  <!-- schema.sql is the source of truth; ship it next to the app so the
       schema initializer can apply it on startup regardless of CWD. -->
  <ItemGroup>
    <None Include="schema.sql" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
